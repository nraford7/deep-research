# Deep Research — API keys
# Copy this file to ~/.env (or ./.env) and fill in whichever you have.
# The dispatcher auto-detects which keys are set and only calls those models.
# At least one key is required. Three or more is the sweet spot.

ANTHROPIC_API_KEY=sk-ant-...     # Claude — https://console.anthropic.com
OPENAI_API_KEY=sk-...            # ChatGPT — https://platform.openai.com
PERPLEXITY_API_KEY=pplx-...      # Perplexity Deep Research — https://www.perplexity.ai/settings/api
GOOGLE_API_KEY=...               # Gemini — https://aistudio.google.com/apikey
XAI_API_KEY=xai-...              # Grok — https://console.x.ai
