# Deep Research — environment variables
# Copy this file to ~/.env (or ./.env) and fill in what you have.
# The dispatcher auto-detects which keys are set and only calls those models.
# At least one model key is required. Three or more is the sweet spot.

# Model API keys
ANTHROPIC_API_KEY=sk-ant-...     # Claude — https://console.anthropic.com
OPENAI_API_KEY=sk-...            # ChatGPT — https://platform.openai.com
PERPLEXITY_API_KEY=pplx-...      # Perplexity Deep Research — https://www.perplexity.ai/settings/api
GOOGLE_API_KEY=...               # Gemini — https://aistudio.google.com/apikey
XAI_API_KEY=xai-...              # Grok — https://console.x.ai

# Optional — raises Semantic Scholar rate limit for lit_search.py
SEMANTIC_SCHOLAR_KEY=

# Optional — your email joins the OpenAlex / Crossref "polite pool" for better rate limits.
# These APIs are free and don't require a key; the email is just an etiquette signal.
CONTACT_EMAIL=
